# PostgreSQL connection string for application data.
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/beagle_db_v2"
# MariaDB connection string for legacy phase-1 import source.
LEGACY_DATABASE_URL="mysql://root:password@127.0.0.1:3306/beagle_db_v1"
# Better Auth signing secret (use 32+ chars in non-local environments).
BETTER_AUTH_SECRET="replace-with-32-plus-char-secret"
# Canonical app URL used by Better Auth callbacks/session logic.
BETTER_AUTH_URL="http://localhost:3000"
# Session max age in seconds (default 14 days).
BETTER_AUTH_SESSION_EXPIRES_IN="1209600"
# Sliding session refresh interval in seconds (default 1 day).
BETTER_AUTH_SESSION_UPDATE_AGE="86400"
# One-time first admin bootstrap (used by `pnpm auth:bootstrap-admin`)
# Leave name empty to fallback to email local-part.
BOOTSTRAP_ADMIN_EMAIL="admin@example.com"
BOOTSTRAP_ADMIN_PASSWORD="replace-with-strong-password"
BOOTSTRAP_ADMIN_NAME="Admin User"
# Password update helper (used by `pnpm auth:set-password`)
SET_PASSWORD_EMAIL="admin@example.com"
SET_PASSWORD_NEW_PASSWORD="replace-with-new-strong-password"
# Optional client-side API base URL override (defaults to same-origin).
NEXT_PUBLIC_API_URL="http://localhost:3000"
# Comma-separated CORS allowlist for API responses.
CORS_ORIGINS="http://localhost:3000"

# Proton Pass references (optional)
# Copy one full block into `.env.local`, `.env.staging`, or `.env.prod`.

# Local (`.env.local`)
# DATABASE_URL=pass://beagle-db-v2/local/DATABASE_URL
# LEGACY_DATABASE_URL=pass://beagle-db-v2/local/LEGACY_DATABASE_URL
# BETTER_AUTH_SECRET=pass://beagle-db-v2/local/BETTER_AUTH_SECRET
# BETTER_AUTH_URL=pass://beagle-db-v2/local/BETTER_AUTH_URL
# BETTER_AUTH_SESSION_EXPIRES_IN=pass://beagle-db-v2/local/BETTER_AUTH_SESSION_EXPIRES_IN
# BETTER_AUTH_SESSION_UPDATE_AGE=pass://beagle-db-v2/local/BETTER_AUTH_SESSION_UPDATE_AGE
# BOOTSTRAP_ADMIN_EMAIL=pass://beagle-db-v2/local/BOOTSTRAP_ADMIN_EMAIL
# BOOTSTRAP_ADMIN_PASSWORD=pass://beagle-db-v2/local/BOOTSTRAP_ADMIN_PASSWORD
# BOOTSTRAP_ADMIN_NAME=pass://beagle-db-v2/local/BOOTSTRAP_ADMIN_NAME
# SET_PASSWORD_EMAIL=pass://beagle-db-v2/local/SET_PASSWORD_EMAIL
# SET_PASSWORD_NEW_PASSWORD=pass://beagle-db-v2/local/SET_PASSWORD_NEW_PASSWORD
# NEXT_PUBLIC_API_URL=pass://beagle-db-v2/local/NEXT_PUBLIC_API_URL
# CORS_ORIGINS=pass://beagle-db-v2/local/CORS_ORIGINS

# Staging (`.env.staging`)
# DATABASE_URL=pass://beagle-db-v2/staging/DATABASE_URL
# LEGACY_DATABASE_URL=pass://beagle-db-v2/staging/LEGACY_DATABASE_URL
# BETTER_AUTH_SECRET=pass://beagle-db-v2/staging/BETTER_AUTH_SECRET
# BETTER_AUTH_URL=pass://beagle-db-v2/staging/BETTER_AUTH_URL
# BETTER_AUTH_SESSION_EXPIRES_IN=pass://beagle-db-v2/staging/BETTER_AUTH_SESSION_EXPIRES_IN
# BETTER_AUTH_SESSION_UPDATE_AGE=pass://beagle-db-v2/staging/BETTER_AUTH_SESSION_UPDATE_AGE
# BOOTSTRAP_ADMIN_EMAIL=pass://beagle-db-v2/staging/BOOTSTRAP_ADMIN_EMAIL
# BOOTSTRAP_ADMIN_PASSWORD=pass://beagle-db-v2/staging/BOOTSTRAP_ADMIN_PASSWORD
# BOOTSTRAP_ADMIN_NAME=pass://beagle-db-v2/staging/BOOTSTRAP_ADMIN_NAME
# SET_PASSWORD_EMAIL=pass://beagle-db-v2/staging/SET_PASSWORD_EMAIL
# SET_PASSWORD_NEW_PASSWORD=pass://beagle-db-v2/staging/SET_PASSWORD_NEW_PASSWORD
# NEXT_PUBLIC_API_URL=pass://beagle-db-v2/staging/NEXT_PUBLIC_API_URL
# CORS_ORIGINS=pass://beagle-db-v2/staging/CORS_ORIGINS

# Prod (`.env.prod`)
# DATABASE_URL=pass://beagle-db-v2/prod/DATABASE_URL
# LEGACY_DATABASE_URL=pass://beagle-db-v2/prod/LEGACY_DATABASE_URL
# BETTER_AUTH_SECRET=pass://beagle-db-v2/prod/BETTER_AUTH_SECRET
# BETTER_AUTH_URL=pass://beagle-db-v2/prod/BETTER_AUTH_URL
# BETTER_AUTH_SESSION_EXPIRES_IN=pass://beagle-db-v2/prod/BETTER_AUTH_SESSION_EXPIRES_IN
# BETTER_AUTH_SESSION_UPDATE_AGE=pass://beagle-db-v2/prod/BETTER_AUTH_SESSION_UPDATE_AGE
# BOOTSTRAP_ADMIN_EMAIL=pass://beagle-db-v2/prod/BOOTSTRAP_ADMIN_EMAIL
# BOOTSTRAP_ADMIN_PASSWORD=pass://beagle-db-v2/prod/BOOTSTRAP_ADMIN_PASSWORD
# BOOTSTRAP_ADMIN_NAME=pass://beagle-db-v2/prod/BOOTSTRAP_ADMIN_NAME
# SET_PASSWORD_EMAIL=pass://beagle-db-v2/prod/SET_PASSWORD_EMAIL
# SET_PASSWORD_NEW_PASSWORD=pass://beagle-db-v2/prod/SET_PASSWORD_NEW_PASSWORD
# NEXT_PUBLIC_API_URL=pass://beagle-db-v2/prod/NEXT_PUBLIC_API_URL
# CORS_ORIGINS=pass://beagle-db-v2/prod/CORS_ORIGINS
