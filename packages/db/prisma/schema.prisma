generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum DogSex {
  MALE
  FEMALE
  UNKNOWN
}

enum ImportKind {
  LEGACY_PHASE1
}

enum ImportStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ImportIssueSeverity {
  INFO
  WARNING
  ERROR
}

model BetterAuthUser {
  id            String              @id
  email         String              @unique
  emailVerified Boolean             @default(false)
  name          String?
  image         String?
  role          String              @default("USER")
  banned        Boolean             @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  sessions      BetterAuthSession[]
  accounts      BetterAuthAccount[]
  importRuns    ImportRun[]

  @@index([role])
}

model BetterAuthSession {
  id             String         @id
  token          String         @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
}

model BetterAuthAccount {
  id                    String         @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model BetterAuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Dog {
  id              String            @id @default(cuid())
  name            String
  sex             DogSex            @default(UNKNOWN)
  birthDate       DateTime?
  breederNameText String?
  sireId          String?
  damId           String?
  breederId       String?
  ekNo            Int?              @unique
  note            String?
  sire            Dog?              @relation("SireRelation", fields: [sireId], references: [id])
  siredPuppies    Dog[]             @relation("SireRelation")
  dam             Dog?              @relation("DamRelation", fields: [damId], references: [id])
  whelpedPuppies  Dog[]             @relation("DamRelation")
  breeder         Breeder?          @relation(fields: [breederId], references: [id])
  registrations   DogRegistration[]
  ownerships      DogOwnership[]
  trialResults    TrialResult[]
  showResults     ShowResult[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([name])
  @@index([sex])
  @@index([birthDate])
  @@index([sireId])
  @@index([damId])
  @@index([breederId])
}

model DogRegistration {
  id             String   @id @default(cuid())
  dogId          String
  registrationNo String   @unique
  source         String
  dog            Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dogId])
}

model Breeder {
  id             String   @id @default(cuid())
  name           String   @unique
  shortCode      String?
  grantedAtRaw   String?
  modifiedAtRaw  String?
  ownerName      String?
  city           String?
  legacyFlag     String?
  detailsSource  String?
  dogs           Dog[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Owner {
  id          String         @id @default(cuid())
  name        String
  postalCode  String         @default("")
  city        String         @default("")
  ownerships  DogOwnership[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([name, postalCode, city])
  @@index([name])
}

model DogOwnership {
  id            String   @id @default(cuid())
  dogId         String
  ownerId       String
  ownershipDate DateTime?
  ownershipDateKey String
  dog           Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([dogId, ownerId, ownershipDateKey])
  @@index([dogId])
  @@index([ownerId])
  @@index([ownershipDate])
}

model TrialResult {
  id               String    @id @default(cuid())
  dogId            String
  eventDate        DateTime
  eventName        String?
  eventPlace       String
  kennelDistrict   String?
  kennelDistrictNo String?
  ke               String?
  lk               String?
  pa               String?
  piste            Decimal?  @db.Decimal(6, 2)
  sija             String?
  haku             Decimal?  @db.Decimal(6, 2)
  hauk             Decimal?  @db.Decimal(6, 2)
  yva              Decimal?  @db.Decimal(6, 2)
  hlo              Decimal?  @db.Decimal(6, 2)
  alo              Decimal?  @db.Decimal(6, 2)
  tja              Decimal?  @db.Decimal(6, 2)
  pin              Decimal?  @db.Decimal(6, 2)
  judge            String?
  legacyFlag       String?
  sourceKey        String    @unique
  dog              Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([eventDate])
  @@index([dogId, eventDate])
}

model ShowResult {
  id         String   @id @default(cuid())
  dogId      String
  eventDate  DateTime
  eventName  String?
  eventPlace String
  resultText String?
  heightText String?
  judge      String?
  legacyFlag String?
  sourceKey  String   @unique
  dog        Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([eventDate])
  @@index([dogId, eventDate])
}

model ImportRun {
  id                  String       @id @default(cuid())
  kind                ImportKind
  status              ImportStatus @default(PENDING)
  dogsUpserted        Int          @default(0)
  ownersUpserted      Int          @default(0)
  ownershipsUpserted  Int          @default(0)
  trialResultsUpserted Int         @default(0)
  showResultsUpserted Int          @default(0)
  errorsCount         Int          @default(0)
  startedAt           DateTime?
  finishedAt          DateTime?
  errorSummary        String?
  createdByUserId     String?
  createdByUser       BetterAuthUser? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  issues              ImportRunIssue[]
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([kind, status])
  @@index([createdByUserId])
}

model ImportRunIssue {
  id             String              @id @default(cuid())
  importRunId    String
  stage          String
  severity       ImportIssueSeverity @default(WARNING)
  code           String
  message        String
  registrationNo String?
  sourceRowId    Int?
  sourceTable    String?
  payloadJson    String?             @db.Text
  importRun      ImportRun           @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  createdAt      DateTime            @default(now())

  @@index([importRunId])
  @@index([importRunId, stage])
  @@index([importRunId, severity])
  @@index([importRunId, code])
}
