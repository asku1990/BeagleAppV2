generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum DogSex {
  MALE
  FEMALE
  UNKNOWN
}

enum ImportKind {
  LEGACY_PHASE1
  LEGACY_PHASE1_5
  LEGACY_PHASE2
  LEGACY_PHASE3
  LEGACY_TRIAL_MIRROR
}

enum ImportStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ImportIssueSeverity {
  INFO
  WARNING
  ERROR
}

enum ShowSourceTag {
  LEGACY_NAY9599
  LEGACY_BEANAY
  LEGACY_BEANAY_TEXT
  WORKBOOK_KENNELLIITTO
  MANUAL_ADMIN
}

enum TrialSourceTag {
  LEGACY_AKOEALL
  KOIRATIETOKANTA_API
}

enum ShowResultValueType {
  FLAG
  CODE
  TEXT
  NUMERIC
  DATE
}

enum ShowWorkbookColumnPolicy {
  IMPORT
  IGNORE
}

enum ShowWorkbookColumnDestinationKind {
  SHOW_EVENT
  SHOW_ENTRY
  SHOW_RESULT_ITEM
}

enum ShowWorkbookTargetField {
  REGISTRATION_NO
  EVENT_DATE
  EVENT_CITY
  EVENT_PLACE
  EVENT_TYPE
  DOG_NAME
  CLASS_VALUE
  QUALITY_VALUE
  JUDGE
  CRITIQUE_TEXT
}

enum ShowWorkbookColumnParseMode {
  TEXT
  DATE
  DEFINITION_FROM_CELL
  FIXED_FLAG
  FIXED_NUMERIC
  FIXED_CODE
  VALUE_MAP
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE
}

enum AuditSource {
  WEB
  SCRIPT
  SYSTEM
}

model BetterAuthUser {
  id            String              @id
  email         String              @unique
  emailVerified Boolean             @default(false)
  name          String?
  image         String?
  role          String              @default("USER")
  banned        Boolean             @default(false)
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  sessions      BetterAuthSession[]
  accounts      BetterAuthAccount[]
  importRuns    ImportRun[]

  @@index([role])
}

model BetterAuthSession {
  id             String         @id
  token          String         @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  userId         String
  impersonatedBy String?
  user           BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
}

model BetterAuthAccount {
  id                    String         @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  user                  BetterAuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model BetterAuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
}

model Dog {
  id              String            @id @default(cuid())
  name            String
  sex             DogSex            @default(UNKNOWN)
  birthDate       DateTime?
  breederNameText String?
  sireId          String?
  damId           String?
  breederId       String?
  ekNo            Int?              @unique
  note            String?
  sire            Dog?              @relation("SireRelation", fields: [sireId], references: [id])
  siredPuppies    Dog[]             @relation("SireRelation")
  dam             Dog?              @relation("DamRelation", fields: [damId], references: [id])
  whelpedPuppies  Dog[]             @relation("DamRelation")
  breeder         Breeder?          @relation(fields: [breederId], references: [id])
  registrations   DogRegistration[]
  ownerships      DogOwnership[]
  titles          DogTitle[]
  trialResults    TrialResult[]
  trialEntries    TrialEntry[]
  showEntries     ShowEntry[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([name])
  @@index([sex])
  @@index([birthDate])
  @@index([sireId])
  @@index([damId])
  @@index([breederId])
}

model DogTitle {
  id        String    @id @default(cuid())
  dogId     String
  awardedOn DateTime?
  titleCode String
  titleName String?
  sortOrder Int       @default(0)
  dog       Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([dogId])
  @@index([dogId, sortOrder])
}

model DogRegistration {
  id             String   @id @default(cuid())
  dogId          String
  registrationNo String   @unique
  source         String
  dog            Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([dogId])
}

model Breeder {
  id            String   @id @default(cuid())
  name          String   @unique
  shortCode     String?
  grantedAtRaw  String?
  modifiedAtRaw String?
  ownerName     String?
  city          String?
  legacyFlag    String?
  detailsSource String?
  dogs          Dog[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Owner {
  id         String         @id @default(cuid())
  name       String
  postalCode String         @default("")
  city       String         @default("")
  ownerships DogOwnership[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@unique([name, postalCode, city])
  @@index([name])
}

model DogOwnership {
  id               String    @id @default(cuid())
  dogId            String
  ownerId          String
  ownershipDate    DateTime?
  ownershipDateKey String
  dog              Dog       @relation(fields: [dogId], references: [id], onDelete: Cascade)
  owner            Owner     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([dogId, ownerId, ownershipDateKey])
  @@index([dogId])
  @@index([ownerId])
  @@index([ownershipDate])
}

model TrialResult {
  id               String   @id @default(cuid())
  dogId            String
  eventDate        DateTime
  eventName        String?
  eventPlace       String
  kennelDistrict   String?
  kennelDistrictNo String?
  ke               String?
  lk               String?
  pa               String?
  piste            Decimal? @db.Decimal(6, 2)
  sija             String?
  haku             Decimal? @db.Decimal(6, 2)
  hauk             Decimal? @db.Decimal(6, 2)
  yva              Decimal? @db.Decimal(6, 2)
  hlo              Decimal? @db.Decimal(6, 2)
  alo              Decimal? @db.Decimal(6, 2)
  tja              Decimal? @db.Decimal(6, 2)
  pin              Decimal? @db.Decimal(6, 2)
  judge            String?
  legacyFlag       String?
  sourceKey        String   @unique
  dog              Dog      @relation(fields: [dogId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([eventDate])
  @@index([dogId, eventDate])
}

model TrialEvent {
  // 1) kokeen tiedot
  id             String   @id @default(cuid())
  sklKoeId       Int?     @unique
  koepaiva       DateTime
  koekunta       String
  jarjestaja     String?
  kennelpiiri    String?
  kennelpiirinro String?
  koemuoto       String?
  rotukoodi      String? // This should be moved to entry level.

  // 10) tuomarit ja vahvistus (event-taso)
  ylituomariNimi   String?
  ylituomariNumero String?

  // technical/event metadata
  legacyEventKey String?      @unique
  ytKertomus     String?      @db.Text
  entries        TrialEntry[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([koepaiva])
  @@index([koekunta, koepaiva])
}

model TrialEntry {
  // identity and relations
  id              String         @id @default(cuid())
  trialEventId    String
  dogId           String?
  yksilointiAvain String         @unique
  lahde           TrialSourceTag

  // 2) koiran tiedot
  koemaasto                  String?
  rekisterinumeroSnapshot    String
  luokka                     String?
  omistajaSnapshot           String?
  omistajanKotikuntaSnapshot String?

  // 3) koe-erat
  era1Alkoi             String?
  era2Alkoi             String?
  era3Alkoi             String?
  era4Alkoi             String?
  hakuMin1              Int?
  hakuMin2              Int?
  hakuMin3              Int?
  hakuMin4              Int?
  ajoMin1               Int?
  ajoMin2               Int?
  ajoMin3               Int?
  ajoMin4               Int?
  hyvaksytytAjominuutit Int?
  ajoajanPisteet        Decimal? @db.Decimal(6, 2)

  // 4) ansiopisteiden keskiarvot ja yhteensa
  hakuEra1                    Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuEra2                    Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuEra3                    Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuEra4                    Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuKeskiarvo               Decimal? @db.Decimal(6, 2)
  haukkuEra1                  Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  haukkuEra2                  Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  haukkuEra3                  Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  haukkuEra4                  Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  haukkuKeskiarvo             Decimal? @db.Decimal(6, 2)
  ajotaitoEra1                Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajotaitoEra2                Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajotaitoEra3                Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajotaitoEra4                Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  yleisvaikutelmaPisteet      Decimal? @db.Decimal(6, 2)
  ajotaitoKeskiarvo           Decimal? @db.Decimal(6, 2)
  ansiopisteetYhteensa        Decimal? @db.Decimal(6, 2)
  tieJaEstetyoskentelyPisteet Decimal? @db.Decimal(6, 2)
  metsastysintoPisteet        Decimal? @db.Decimal(6, 2)

  // 5) tappiopisteiden summat
  hakuloysyysTappioEra1     Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuloysyysTappioEra2     Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuloysyysTappioEra3     Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuloysyysTappioEra4     Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  hakuloysyysTappioYhteensa Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajoloysyysTappioEra1      Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajoloysyysTappioEra2      Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajoloysyysTappioEra3      Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajoloysyysTappioEra4      Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  ajoloysyysTappioYhteensa  Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.
  tappiopisteetYhteensa     Decimal? @db.Decimal(6, 2) // Whole-number AJOK source value; candidate for Int conversion.

  // 6) pisteet ja tulos
  loppupisteet      Decimal? @db.Decimal(6, 2)
  palkinto          String?
  legacySijoitusRaw String? // Raw legacy SIJA text from akoeall.
  sijoitus          String? // Canonical placement for modern AJOK writes.
  koiriaLuokassa    Int?
  kokokaudenkoe     Boolean? // Entry-level whole-season trial flag.

  // 7) olosuhteet
  keli String?

  // 8) huomautukset ja tilat
  luopui          Boolean?
  suljettu        Boolean?
  keskeytetty     Boolean?
  huomautusTeksti String?  @db.Text

  // 10) tuomarit ja vahvistus (entry-taso)
  ylituomariNimiSnapshot   String?
  ylituomariNumeroSnapshot String? // this should be int i think?
  ryhmatuomariNimi         String?
  palkintotuomariNimi      String?

  // technical storage
  raakadataJson String? @db.Text
  notes         String? @db.Text

  // 9) lisatiedot (asteikko/rastit)
  lisatiedot TrialLisatietoItem[]
  trialEvent TrialEvent           @relation(fields: [trialEventId], references: [id], onDelete: Cascade)
  dog        Dog?                 @relation(fields: [dogId], references: [id], onDelete: SetNull)
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([trialEventId, rekisterinumeroSnapshot])
  @@index([dogId])
  @@index([trialEventId])
  @@index([loppupisteet])
}

model TrialLisatietoItem {
  id           String     @id @default(cuid())
  trialEntryId String
  koodi        String
  nimi         String
  era1Arvo     String?
  era2Arvo     String?
  era3Arvo     String?
  era4Arvo     String?
  jarjestys    Int?
  trialEntry   TrialEntry @relation(fields: [trialEntryId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([trialEntryId, koodi])
  @@index([koodi])
  @@index([trialEntryId])
}

model LegacyAkoeall {
  rekno          String   @map("REKNO") @db.VarChar(20)
  tappa          String   @map("TAPPA") @db.VarChar(50)
  tappv          String   @map("TAPPV") @db.VarChar(8)
  kennelpiiri    String?  @map("KENNELPIIRI") @db.VarChar(50)
  kennelpiirinro String?  @map("KENNELPIIRINRO") @db.Char(3)
  ke             String?  @map("KE") @db.Char(1)
  lk             String?  @map("LK") @db.Char(1)
  pa             String?  @map("PA") @db.Char(1)
  piste          Decimal? @map("PISTE") @db.Decimal(6, 2)
  sija           String?  @map("SIJA") @db.VarChar(5)
  haku           Decimal? @map("HAKU") @db.Decimal(6, 2)
  hauk           Decimal? @map("HAUK") @db.Decimal(6, 2)
  yva            Decimal? @map("YVA") @db.Decimal(6, 2)
  hlo            Decimal? @map("HLO") @db.Decimal(6, 2)
  alo            Decimal? @map("ALO") @db.Decimal(6, 2)
  tja            Decimal? @map("TJA") @db.Decimal(6, 2)
  pin            Decimal? @map("PIN") @db.Decimal(6, 2)
  tuom1          String?  @map("TUOM1") @db.VarChar(20)
  muokattuRaw    String   @map("MUOKATTU") @db.VarChar(19)
  vara           String?  @map("VARA") @db.Char(3)
  rawPayloadJson String   @map("raw_payload_json") @db.Text
  sourceHash     String?  @map("source_hash") @db.VarChar(64)
  importedAt     DateTime @default(now()) @map("imported_at")

  @@id([rekno, tappa, tappv])
  @@index([rekno])
  @@index([tappa, tappv])
  @@index([tappv, tappa])
  @@map("legacy_akoeall")
}

