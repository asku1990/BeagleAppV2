{
  "name": "@beagle/server",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "import:phase1": "node --import tsx/esm scripts/run-legacy-phase1.ts",
    "import:issues": "node --import tsx/esm scripts/list-import-issues.ts",
    "import:issues:csv": "node --import tsx/esm scripts/export-import-issues-csv.ts"
  },
  "dependencies": {
    "@beagle/auth": "workspace:*",
    "@beagle/contracts": "workspace:*",
    "@beagle/db": "workspace:*",
    "better-auth": "^1.4.18"
  }
}
