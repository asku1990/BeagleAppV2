{
  "name": "beagle-app-v2",
  "version": "0.6.1",
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev": "pnpm --filter @beagle/web dev",
    "build": "turbo build",
    "vercel:build": "bash ./scripts/vercel-build.sh",
    "vercel:ignored-build": "bash ./scripts/vercel-ignored-build.sh",
    "lint": "turbo lint",
    "format": "prettier . --write",
    "typecheck": "turbo typecheck",
    "test": "pnpm test:coverage && pnpm test:coverage:global-check",
    "test:unit": "turbo test:unit",
    "test:coverage": "turbo test:coverage --concurrency=1",
    "test:coverage:global-check": "node scripts/check-global-coverage.mjs",
    "test:e2e": "turbo test:e2e --",
    "test:playwright": "pnpm --filter @beagle/web test:playwright",
    "test:playwright:report": "pnpm --filter @beagle/web exec playwright show-report ../../playwright-report",
    "db:generate": "pnpm --filter @beagle/db exec prisma generate",
    "db:studio": "pnpm --filter @beagle/db exec prisma studio",
    "db:migrate": "echo 'Use pnpm db:migrate:dev (with -- --name <migration>) or pnpm db:push for no migration files.' && exit 1",
    "db:migrate:dev": "pnpm --filter @beagle/db exec prisma migrate dev",
    "db:migrate:reset": "pnpm --filter @beagle/db exec prisma migrate reset",
    "db:deploy": "pnpm --filter @beagle/db exec prisma migrate deploy",
    "db:migrate:deploy": "pnpm db:deploy",
    "db:seed:initial-test-data": "pnpm --filter @beagle/db seed:initial-test-data",
    "db:dump": "bash ./scripts/db/dump.sh",
    "db:restore": "bash ./scripts/db/restore.sh",
    "audit:prune": "pnpm --filter @beagle/db audit:prune",
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config packages/server/auth/better-auth.ts",
    "auth:migrate": "pnpm dlx @better-auth/cli@latest migrate --config packages/server/auth/better-auth.ts",
    "auth:bootstrap-admin": "pnpm --filter @beagle/server exec tsx scripts/bootstrap-admin.ts",
    "auth:set-password": "pnpm --filter @beagle/server exec tsx scripts/set-user-password.ts",
    "db:push": "pnpm --filter @beagle/db exec prisma db push",
    "import:phase1": "pnpm --filter @beagle/server import:phase1 --",
    "import:issues": "pnpm --filter @beagle/server import:issues --",
    "import:issues:csv": "pnpm --filter @beagle/server import:issues:csv --",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.19.10",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
